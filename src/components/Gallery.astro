---
import { Image } from 'astro:assets'
interface Props {
    id: string,
    path: string,
    cols: number,
    width: string
}
const { id, path, cols, width } = Astro.props
const data = import.meta.glob<{ default: ImageMetadata }>(`/src/assets/**/*.{jpeg,jpg,JPG,JPEG,png,PNG,gif}`, { eager: true })
const images = Object.keys(data).filter(image => image.startsWith(path))
const columns = [];
for (var i = 0; i < cols; i++) {
    columns[i] = Array()
}
for (var i = 0; i < images.length; i++) {
    columns[i % cols].push(images[i])
}
---

<div class="gallery" id=`${id}-gallery`>
    {columns.map(column => (
        <div class="column">
            {column.map(path => (
                <Image src={data[path].default} alt="" width={data[path].default.width} height={data[path].default.height}/>
            ))}
        </div>
    ))}
</div>
<dialog class="lightbox" id=`${id}-lightbox`>
    
    <div class="nav-button close">
        <svg xmlns="http://www.w3.org/2000/svg" width="1.5em" height="1.5em" viewBox="0 0 24 24">
            <path d="M0 0h24v24H0z" fill="none" />
            <path fill="currentColor" d="m12 13.4l-4.9 4.9q-.275.275-.7.275t-.7-.275t-.275-.7t.275-.7l4.9-4.9l-4.9-4.9q-.275-.275-.275-.7t.275-.7t.7-.275t.7.275l4.9 4.9l4.9-4.9q.275-.275.7-.275t.7.275t.275.7t-.275.7L13.4 12l4.9 4.9q.275.275.275.7t-.275.7t-.7.275t-.7-.275z" />
        </svg>
    </div>
    <div class="nav-button left">
        <svg xmlns="http://www.w3.org/2000/svg" width="min(4vw, 4vh)" height="min(4vw, 4vh)" viewBox="0 0 24 24">
            <path d="M0 0h24v24H0z" fill="none" />
            <path fill="currentColor" d="M16.62 2.99a1.25 1.25 0 0 0-1.77 0L6.54 11.3a.996.996 0 0 0 0 1.41l8.31 8.31c.49.49 1.28.49 1.77 0s.49-1.28 0-1.77L9.38 12l7.25-7.25c.48-.48.48-1.28-.01-1.76" />
        </svg>
    </div>
    <img/>
    <div class="nav-button right">
        <svg xmlns="http://www.w3.org/2000/svg" width="min(4vw, 4vh)" height="min(4vw, 4vh)" viewBox="0 0 24 24">
            <path d="M0 0h24v24H0z" fill="none" />
            <path fill="currentColor" d="M7.38 21.01c.49.49 1.28.49 1.77 0l8.31-8.31a.996.996 0 0 0 0-1.41L9.15 2.98c-.49-.49-1.28-.49-1.77 0s-.49 1.28 0 1.77L14.62 12l-7.25 7.25c-.48.48-.48 1.28.01 1.76" />
        </svg>
    </div>

</dialog>

<script define:vars={{id}}>
    const lightbox = document.getElementById(`${id}-lightbox`);
    const gallery = document.getElementById(`${id}-gallery`);
    const close = lightbox.querySelector('.close');
    const left = lightbox.querySelector('.left');
    const right = lightbox.querySelector('.right');
    const images = gallery.querySelectorAll('img');
    var index = 0;
    images.forEach(image => {
        image.addEventListener('click', () => {
            const img = lightbox.querySelector('img');
            img.src = image.src;
            lightbox.showModal();
            lightbox.classList.add('show');
            index = Array.from(images).indexOf(image);
        })
    })
    lightbox.addEventListener('transitionend', () => {
        if (!lightbox.classList.contains('show')) {
            lightbox.querySelectorAll('img').forEach(img => {
                img.removeAttribute('src');
            });
            lightbox.close();
        }
    })
    lightbox.addEventListener('click', e => {
        if (e.target == e.currentTarget) {
            lightbox.classList.remove('show')
        }
    })
    lightbox.addEventListener('cancel', (e) => {
        e.preventDefault();
        lightbox.classList.remove('show');
    });
    close.addEventListener('click', e => {
        lightbox.classList.remove('show');
    })
    left.addEventListener('click', () => {
        const img = lightbox.querySelector('img');
        index = index == 0 ? images.length - 1 : index - 1;
        document.startViewTransition(() => { img.src = images[index].src; });
    })
    right.addEventListener('click', () => {
        const img = lightbox.querySelector('img');
        index = (index + 1) % images.length;
        document.startViewTransition(() => { img.src = images[index].src; });
    })
</script>

<style define:vars={{width: `${width}`}}>

    .nav-button {
        position: absolute;
        color: white;
        align-self: center;
        cursor: pointer;
        opacity: 50%;
        transition: scale 0.2s, opacity 0.2s;
    }

    .nav-button:hover {
        scale: 110%;
        opacity: 100%;
    }

    .left {
        left: 0;
        transform-origin: left;
    }

    .right {
        right: 0;
        transform-origin: right;
    }

    .close {
        position: absolute;
        top: 0;
        left: 0;
    }

    .gallery {
        display: flex;
        flex-wrap: wrap;
        flex-direction: row;
        justify-items: center;
        justify-content: center;
        width: 100%;
    }

    .column {
        display: flex;
        flex-wrap: wrap;
        flex-direction: column;
        width: var(--width);
        gap: 0.5em;
        margin: 0.25em;
    }

    .gallery img {
        width: 100%;
        height: auto;
        border-radius: 1%;
        cursor: pointer;
        transition: scale 0.2s;
    }

    .gallery img:hover {
        scale: 97.5%;
    }

    @media (prefers-reduced-motion: no-preference) {
        .lightbox {
            transition: opacity 0.1s, scale 0.1s, filter 0.1s;
            transition-timing-function: ease-out;
            user-select: none;
        }

        .lightbox::backdrop {
            background: transparent;
            backdrop-filter: none;
            transition: background 0.1s, backdrop-filter 0.1s;
        }

        .lightbox.show::backdrop {
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(2px);
        }

        .lightbox[open].show {
            scale: 100%;
            opacity: 100%;
            filter: none;
        }

        .lightbox[open] {
            display: flex;
            justify-self: center;
            justify-content: center;
            align-self: center;
            margin: 0;
            padding: 0;
            width: 75%;
            height: 75%;
            border: none;
            background: transparent;
            scale: 95%;
            opacity: 0%;
            filter: blur(2px);
        }

        :global(.lightbox img) {
            display: block;
            width: 90%;
            height: auto;
            object-fit: contain;
        }
    }

</style>