---
import { Image } from 'astro:assets'
interface Props {
    id: string,
    path: string,
    cols: number,
    width: string
}
const { id, path, cols, width } = Astro.props
const data = import.meta.glob<{ default: ImageMetadata }>(`/src/assets/**/*.{jpeg,jpg,JPG,JPEG,png,PNG,gif}`, { eager: true })
const images = Object.keys(data).filter(image => image.startsWith(path))
const columns = [];
for (var i = 0; i < cols; i++) {
    columns[i] = Array()
}
for (var i = 0; i < images.length; i++) {
    columns[i % cols].push(images[i])
}
---

<div class="gallery" id=`${id}-gallery`>
    {columns.map(column => (
        <div class="column">
            {column.map(path => (
                <Image src={data[path].default} alt="" width={data[path].default.width} height={data[path].default.height}/>
            ))}
        </div>
    ))}
</div>
<dialog class="lightbox" id=`${id}-lightbox`/>

<script define:vars={{id}}>
    const lightbox = document.getElementById(`${id}-lightbox`);
    const gallery = document.getElementById(`${id}-gallery`);
    const images = gallery.querySelectorAll('img');
    images.forEach(image => {
        image.addEventListener('click', () => {
            const img = document.createElement('img');
            lightbox.appendChild(img);
            img.src = image.src;
            lightbox.showModal();
            lightbox.classList.add('show');
        })
    })
    lightbox.addEventListener('transitionend', () => {
        if (!lightbox.classList.contains('show')) {
            lightbox.querySelectorAll('img').forEach(img => {
                img.remove();
            });
            lightbox.close();
        }
    })
    lightbox.addEventListener('click', e => {
        if (e.target == e.currentTarget) {
            lightbox.classList.remove('show')
        }
    })
    lightbox.addEventListener('cancel', (e) => {
        e.preventDefault();
        lightbox.classList.remove('show');
    });
</script>

<style define:vars={{width: `${width}`}}>
    .gallery {
        display: flex;
        flex-wrap: wrap;
        flex-direction: row;
        justify-items: center;
        justify-content: center;
        width: 100%;
    }

    .column {
        display: flex;
        flex-wrap: wrap;
        flex-direction: column;
        width: var(--width);
        gap: 0.5em;
        margin: 0.25em;
    }

    .gallery img {
        width: 100%;
        height: auto;
        border-radius: 1%;
        cursor: pointer;
    }

    @media (prefers-reduced-motion: no-preference) {
        .lightbox {
            transition: top 0.1s, scale 0.1s, filter 0.1s;
            transition-timing-function: ease-out;
        }

        .lightbox::backdrop {
            background: transparent;
            backdrop-filter: none;
            transition: background 0.1s, backdrop-filter 0.1s;
        }

        .lightbox.show::backdrop {
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(2px);
        }

        .lightbox[open].show {
            scale: 100%;
            opacity: 100%;
            filter: none;
        }

        .lightbox[open] {
            display: flex;
            justify-self: center;
            justify-content: center;
            align-self: center;
            margin: 0;
            padding: 0;
            width: 75%;
            height: 75%;
            border: none;
            background: transparent;
            scale: 95%;
            opacity: 0%;
            filter: blur(5px);
        }
    }
    :global(.lightbox img) {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

</style>