---
import type { CollectionEntry } from 'astro:content'
import { Image } from 'astro:assets'
import { render } from 'astro:content'
interface Props {
    work: CollectionEntry<'works'>
}
const { work } = Astro.props
const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/*.{jpeg,jpg,JPG,JPEG,png,PNG,gif}', { eager: true })
const matchedKey = Object.keys(images).find(key => key.endsWith('/' + work.data.thumbnail))
if (!matchedKey) throw new Error(`Thumbnail not found: ${work.data.thumbnail}`)
const { Content } = await render(work)
const color = work.data.type == "swe" ? 'var(--swe-color)' : 'var(--art-color)'
---

<div style={`--color: ${color}`} class="project-container">
    <Image src={images[matchedKey].default} alt="" style="width: 100%; height: auto; border-radius: 1%"/>
    <h3>{work.data.title}</h3>
    {(work.data.date.length > 0) && <h4>{work.data.date}</h4>}
    <p>{work.data.summary}</p>
    <button class=`cta-button learn ${work.data.type}` id={`${work.id}-learn`}>Learn More</a>
</div>
<dialog class="dialogue" id=`${work.id}-dialogue`>
    <div class="title">
        <button class="close-button" id=`${work.id}-close`>
            <svg xmlns="http://www.w3.org/2000/svg" width="2em" height="2em" viewBox="0 0 24 24">
                <path d="M0 0h24v24H0z" fill="none" />
                <path fill="currentColor" d="M11.03 8.53a.75.75 0 1 0-1.06-1.06l-4 4a.75.75 0 0 0 0 1.06l4 4a.75.75 0 1 0 1.06-1.06l-2.72-2.72H18a.75.75 0 0 0 0-1.5H8.31z" />
            </svg>
        </button>
        <h3>{work.data.title}</h3>
    </div>
    <div class="description">
        <Content />
    </div>
</dialog>

<script define:vars={{work}}>
    const dialog = document.getElementById(`${work.id}-dialogue`)
    const openDialog = document.getElementById(`${work.id}-learn`)
    const closeDialog = document.getElementById(`${work.id}-close`)
    openDialog.addEventListener('click', () => {
        dialog.classList.remove('show');
        dialog.showModal();
        dialog.classList.add('show');
    })
    closeDialog.addEventListener('click', () => {
        dialog.classList.remove('show');
    })
    dialog.addEventListener('transitionend', () => {
        if (!dialog.classList.contains('show')) {
            const iframes = dialog.querySelectorAll('iframe');
            iframes.forEach(iframe => {
                const src = iframe.src;
                iframe.src = src;
            })
            dialog.close();
        }
    })
    dialog.addEventListener('cancel', (e) => {
        e.preventDefault();
        dialog.classList.remove('show');
    });
    dialog.addEventListener('click', (e) => {
        if (e.target == e.currentTarget) {
            dialog.classList.remove('show');
        }
    })
</script>

<style>
    
    :global(.dialogue a:link) {
        color: var(--link-color)
    }

    :global(.dialogue a:visited) {
        color: var(--link-color)
    }

    @media (prefers-reduced-motion: no-preference) {
        .dialogue::backdrop {
            background: rgba(0, 0, 0, 0);
            backdrop-filter: none;
            transition: background 0.25s, backdrop-filter 0.25s;
        }

        .dialogue.show::backdrop {
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(2px);
        }

        .dialogue {
            transition: top 0.25s, opacity 0.25s;
            transition-timing-function: ease-out;
        }

        .dialogue[open].show {
            top: 0rem;
            opacity: 100%;
        }

        .dialogue[open] {
            display: flex;
            flex-direction: column;
            align-self: center;
            justify-self: center;
            width: 50rem;
            height: 40rem;
            background-color: rgba(0, 0, 0, 0.75);
            border-radius: 1%;
            color:white;
            border: none;
            top: 5rem;
            opacity: 0%;
        }
    }
    .description {
        padding: 1em 3em;
        line-height: 1.5em;
        height: 35em;
        flex: 1;
        overflow-y: auto;
    }

    :global(.description ul) {
        list-style-position: inside;
        padding-left: 2em;
    }

    .close-button {
        position: absolute;
        aspect-ratio: 1 / 1;
        opacity: 50%;
        width: 2em;
        color: white;
        background: none;
        border: none;
        position: relative;
        cursor: pointer;
        overflow: hidden;
        transition: scale 0.2s, opacity 0.2s;
    }

    .close-button:hover {
        scale: 125%;
        opacity: 100%;
    }

    .title {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 3em;
        padding: 1em;
        border-bottom: 0.1em solid rgb(255, 255, 255, 20%);
    }

    .title h3 {
        padding-top: 0.2em;
    }

    .project-container {
        display: flex;
        flex-direction: column;
        justify-content: start;
        border-radius: 0.25em;
        padding: 2em;
        margin: 1em 0;
        height: 100%;
        max-width: 25em;
        min-width: 25em;
        background-color: rgba(0, 0, 0, 0.3);
        gap: 0.2em;
    }

    .project-container p {
        font-size: 0.95rem;
    }

    .project-container img {
        aspect-ratio: 1 / 1;
        width: 90%;
        height: width;
        object-fit: contain;
        object-position: center;
        margin-bottom: 1em;
    }

    .learn {
        margin-right: auto;
        border: none;
        color:white;
        margin-top: auto;
        font-size: 0.9rem;
        font-weight: 400;
        font-family: Roboto, 'TikTok Sans', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background-color: color-mix(in srgb, var(--color) 50%, transparent);
        cursor: pointer;
    }

</style>